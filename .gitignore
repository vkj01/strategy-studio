# Ship the market-data DuckDBs (options + equity) -- the app needs them at runtime.
# Do NOT ship per-user data (backtest runs + AI chats): those now live in the Neon
# database, keyed per user. Only ignore runtime junk + secrets.
__pycache__/
*.pyc
*.pyo
*.log
.env
.env.*
stockmock/generated_strategies/
stockmock/generated/
.streamlit/secrets.toml
.DS_Store

# per-user data now lives in Neon, not files
data/conversations/
data/runs.duckdb
